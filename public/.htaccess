<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force trailing slash for all non-file/non-directory requests
  # This makes the URL look like /home/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !(.*)/$
  RewriteRule ^(.*)$ $1/ [L,R=301]

  # 2. Serve the index.html inside the folder
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^(.*)/$ $1/index.html [L]

  # 3. Handle 404 errors safely
  ErrorDocument 404 /404/index.html
</IfModule>
