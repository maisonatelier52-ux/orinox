# Clean .htaccess for Next.js trailingSlash: true export
# This configuration relies on Next.js folder structure (e.g. /home/index.html)
# which cPanel/Apache serves natively with a trailing slash.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Handle 404 errors by pointing to the exported 404 page
  ErrorDocument 404 /404/index.html

  # Optional: Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>
