<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force remove trailing slash if someone types it manually
  # This prevents the "UI gone" issue by keeping the URL at the root level
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} (.+)/$
  RewriteRule ^ %1 [R=301,L]

  # 2. Serve the .html file for clean URLs (e.g., /home serves home.html)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # 3. Handle 404 errors
  ErrorDocument 404 /404.html
</IfModule>
